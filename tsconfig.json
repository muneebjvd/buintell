{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@buintell/*": [
        "packages/*/src"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ],
  "include": []
}